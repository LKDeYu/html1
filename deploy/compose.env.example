# Copy this file to .env on the ECS server, then replace every placeholder.

# Public access
PUBLIC_HOST=your-ecs-public-ip
NEXT_PUBLIC_SITE_URL=http://your-ecs-public-ip
NEXT_PUBLIC_WALINE_SERVER_URL=/waline
# Optional public status-page link shown in the operations dashboard.
NEXT_PUBLIC_UPTIME_STATUS_URL=

# Waline site settings
SITE_NAME=Coordinate Zero
SITE_URL=http://your-ecs-public-ip
# Waline derives its public API URL as SITE_URL/waline.
SECURE_DOMAINS=your-ecs-public-ip
AUTHOR_EMAIL=yuany257093418@gmail.com
JWT_TOKEN=replace-with-a-long-random-string

# MySQL persistence for Waline
MYSQL_DATABASE=waline
MYSQL_USER=waline
MYSQL_PASSWORD=replace-with-a-strong-mysql-password
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password

# Optional safety controls
IPQPS=60
COMMENT_AUDIT=false
DISABLE_REGION=true
DISABLE_USERAGENT=false

# Read-only operations dashboard
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=
# Temporary HTTP testing only. Change back to false after HTTPS is enabled.
OPS_ALLOW_INSECURE_HTTP=false
OPS_USE_MOCK_DATA=false

# Host-side backup scripts (not passed into the web container)
OPS_BACKUP_DIR=/var/backups/coordinate-zero/mysql
OPS_BACKUP_RETENTION=7
